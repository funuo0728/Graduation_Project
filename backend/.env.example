APP_NAME=ZJGSU-IEE-Portal
DATABASE_URL=sqlite+aiosqlite:///./data.db

# MySQL example:
# DATABASE_URL=mysql+aiomysql://root:root@127.0.0.1:3306/iee_portal?charset=utf8mb4

# Optional: OpenAI-compatible endpoint for agent chat
# Example: http://localhost:11434/v1  (Ollama OpenAI compatibility)
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# Aliyun DashScope (Qwen) - OpenAI compatible mode
# If you only provide DASHSCOPE_API_KEY, backend will default to:
#   base_url=https://dashscope.aliyuncs.com/compatible-mode/v1
#   model=qwen-plus
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus

# Admin token for triggering scrape from frontend
ADMIN_TOKEN=
